{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/qwen/qwen3.6-plus",
  "autoupdate": true,
  "snapshot": true,
  "provider": {
    "anthropic": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 30000,
        "setCacheKey": true
      }
    }
  },
  "permission": {
    "external_directory": "allow",
    "bash": "allow",
    "edit": "ask",
    "write": "ask"
  },
  "instructions": ["AGENTS.md"],
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/build/**",
      "**/.dart_tool/**",
      "**/ios/Pods/**",
      "**/android/.gradle/**",
      "**/.pub-cache/**",
      "**/*.lock",
      "**/hs_err_*.log",
      "**/flutter_*.log",
      "**/debug.log",
      "**/.claude/worktrees/**"
    ]
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/Users/nims/StudioProjects/farkha"]
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"]
    },
    "mysql": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@berthojoris/mcp-mysql-server"
      ],
      "environment": {
        "MYSQL_HOST": "127.0.0.1",
        "MYSQL_PORT": "8889",
        "MYSQL_USER": "root",
        "MYSQL_PASSWORD": "root",
        "MYSQL_DATABASE": "farkha"
      }
    }
  }
}
